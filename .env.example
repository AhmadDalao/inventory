APP_NAME="Inventory HQ"
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Riyadh
APP_URL=https://inventory.ahmaddalao.com

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4

# Optional fallback. Prefer Website Control > Purchase OCR for live key updates.
# Enables server-side Arabic/English scanned PDF OCR for purchase documents.
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-5.5
OPENAI_OCR_ENABLED=false
